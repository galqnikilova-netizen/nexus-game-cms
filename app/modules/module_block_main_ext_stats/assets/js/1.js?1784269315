(function () {
    'use strict';

    const MODULE = 'module_block_main_ext_stats';
    const TAB_KEY = 'tab_ext_stats';
    const DEFAULT_TAB = 'lastBans';
    const AVATAR_PLACEHOLDER = '/storage/cache/img/avatars/1_avatar.jpg';
    const SCROLL_STEP = 0.8;
    const WHEEL_SPEED = 1.1;
    const WHEEL_EASE = 0.22;
    const $ = (selector, root = document) => root.querySelector(selector);
    const $$ = (selector, root = document) => Array.from(root.querySelectorAll(selector));

    const phrase = key => get_translate_module_phrase(MODULE, key);
    const esc = value => String(value ?? '').replace(/[&<>"']/g, char => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;',
    }[char]));
    const time = timestamp => {
        if (!timestamp) return '';

        const date = new Date(Number(timestamp) * 1000);
        if (Number.isNaN(date.getTime())) return '';

        const part = value => String(value).padStart(2, '0');
        return `${part(date.getDate())}.${part(date.getMonth() + 1)}.${date.getFullYear()} ${part(date.getHours())}:${part(date.getMinutes())}`;
    };

    window.avatar = window.avatar || [];
    let activeTab = null;
    let loadId = 0;
    const responseCache = {};
    const renderState = {};
    const feedPanelCache = {};
    const REFRESH_INTERVAL = 10000;
    let refreshTimer = null;

    function rememberAvatar(check, steamid) {
        if ((check === 1 || check === true) && steamid && !window.avatar.includes(steamid)) {
            window.avatar.push(steamid);
        }
    }

    function updateEdges(scroller, track) {
        const max = track.scrollWidth - track.clientWidth;
        scroller.classList.toggle('is-start', track.scrollLeft <= 1);
        scroller.classList.toggle('is-end', track.scrollLeft >= max - 1);
    }

    function bindWheel(track) {
        let target = track.scrollLeft;
        let current = track.scrollLeft;
        let active = false;

        const normalize = e => e.deltaY * (e.deltaMode === 1 ? 16 : e.deltaMode === 2 ? window.innerHeight : 1);
        const tick = () => {
            const diff = target - current;

            if (Math.abs(diff) < 0.5) {
                track.scrollLeft = target;
                active = false;
                return;
            }

            current += diff * WHEEL_EASE;
            track.scrollLeft = current;
            requestAnimationFrame(tick);
        };

        track.addEventListener('scroll', () => {
            if (!active) {
                target = current = track.scrollLeft;
            }
        }, { passive: true });

        track.addEventListener('wheel', e => {
            if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;

            const max = track.scrollWidth - track.clientWidth;
            const delta = normalize(e);

            if (max <= 0 || (delta > 0 && target >= max - 0.5) || (delta < 0 && target <= 0)) return;

            e.preventDefault();
            target = Math.max(0, Math.min(max, target + delta * WHEEL_SPEED));

            if (!active) {
                active = true;
                current = track.scrollLeft;
                requestAnimationFrame(tick);
            }
        }, { passive: false });
    }

    function initScroller(scroller) {
        if (scroller.esExtStats) return;

        const track = $('[data-es-track]', scroller);
        if (!track) return;

        const refresh = () => updateEdges(scroller, track);
        bindWheel(track);

        $$('[data-es-nav]', scroller).forEach(btn => {
            btn.addEventListener('click', () => {
                const dir = btn.dataset.esNav === 'next' ? 1 : -1;
                track.scrollBy({ left: dir * track.clientWidth * SCROLL_STEP, behavior: 'smooth' });
            });
        });

        track.addEventListener('scroll', refresh, { passive: true });
        window.addEventListener('resize', refresh);
        if ('ResizeObserver' in window) new ResizeObserver(refresh).observe(track);

        refresh();
        scroller.esExtStats = { refresh, track };
    }

    const AVATAR_ANIM_MS = 600;
    const AVATAR_EASE = 'cubic-bezier(0.4, 0, 0.2, 1)';

    function prefersReducedMotion() {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    }

    function getCollapsedHeightPx(wrapper) {
        const raw = getComputedStyle(wrapper).getPropertyValue('--es-avatars-collapsed-height').trim();
        if (raw.endsWith('rem')) {
            const root = parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
            return parseFloat(raw) * root;
        }

        return parseFloat(raw) || 0;
    }

    function syncContentExpanded(container) {
        const content = container?.closest('.es__content') || $('.es__content');
        if (!content) return;

        const expanded = Boolean(container?.classList.contains('is-expanded') && !container.hidden);
        content.classList.toggle('es__content--expanded', expanded);
        content.classList.toggle('es__content--collapsing', container?.classList.contains('is-collapsing'));
    }

    function getCollapsedContentHeight(container, wrapper) {
        const collapsedWrapperPx = getCollapsedHeightPx(wrapper);
        if (!container) return collapsedWrapperPx;

        const scroller = container.closest('.es__scroller-avatars') || container;
        return Math.max(collapsedWrapperPx, scroller.offsetHeight);
    }

    function animateContentHeight(content, fromPx, toPx, onDone) {
        if (!content) {
            onDone();
            return;
        }

        content.classList.add('es__content--collapsing');
        content.classList.remove('es__content--expanded');
        content.style.overflow = 'hidden';
        content.style.transition = `max-height ${AVATAR_ANIM_MS}ms ${AVATAR_EASE}`;
        content.style.maxHeight = `${fromPx}px`;
        void content.offsetHeight;
        content.style.maxHeight = `${toPx}px`;

        let done = false;
        const complete = () => {
            if (done) return;
            done = true;
            content.removeEventListener('transitionend', onTransitionEnd);
            onDone();
        };
        const onTransitionEnd = (e) => {
            if (e.target !== content || e.propertyName !== 'max-height') return;
            complete();
        };

        content.addEventListener('transitionend', onTransitionEnd);
        setTimeout(complete, AVATAR_ANIM_MS + 80);
    }

    function clearContentHeightAnimation(content) {
        if (!content) return;

        content.classList.remove('es__content--collapsing');
        content.style.removeProperty('max-height');
        content.style.removeProperty('transition');
        content.style.removeProperty('overflow');
    }

    function runHeightTransition(wrapper, onDone) {
        wrapper.classList.add('is-animating');

        let done = false;
        const complete = () => {
            if (done) return;
            done = true;
            wrapper.classList.remove('is-animating');
            wrapper.removeEventListener('transitionend', onTransitionEnd);
            onDone();
        };
        const onTransitionEnd = (e) => {
            if (e.target !== wrapper || e.propertyName !== 'height') return;
            complete();
        };

        wrapper.addEventListener('transitionend', onTransitionEnd);
        setTimeout(complete, AVATAR_ANIM_MS + 50);
    }

    function finishAvatarCollapse(container, wrapper) {
        const content = container?.closest('.es__content');
        const collapsedContentPx = getCollapsedContentHeight(container, wrapper);

        container.classList.remove('is-expanded', 'is-collapsing');
        wrapper.classList.remove('is-animating');
        wrapper.style.removeProperty('--es-avatars-expanded-height');

        if (content) {
            content.style.maxHeight = `${collapsedContentPx}px`;
        }

        clearContentHeightAnimation(content);
        syncContentExpanded(container);
        setAvatarOverflow(container, true);
    }

    function collapseAvatarPanel(container, wrapper, toggle) {
        toggle.textContent = toggle.dataset.showText || 'Show all';

        if (prefersReducedMotion()) {
            finishAvatarCollapse(container, wrapper);
            return;
        }

        const content = container.closest('.es__content');
        const collapsedPx = getCollapsedHeightPx(wrapper);
        const collapsedContentPx = getCollapsedContentHeight(container, wrapper);
        const startWrapperHeight = wrapper.offsetHeight;
        const startContentHeight = content?.offsetHeight || startWrapperHeight;

        container.classList.add('is-collapsing');
        syncContentExpanded(container);

        wrapper.style.setProperty('--es-avatars-expanded-height', `${startWrapperHeight}px`);
        void wrapper.offsetHeight;
        wrapper.style.setProperty('--es-avatars-expanded-height', `${collapsedPx}px`);

        let wrapperDone = false;
        let contentDone = !content;

        const finish = () => {
            if (!wrapperDone || !contentDone) return;
            finishAvatarCollapse(container, wrapper);
        };

        animateContentHeight(content, startContentHeight, collapsedContentPx, () => {
            contentDone = true;
            finish();
        });

        runHeightTransition(wrapper, () => {
            wrapperDone = true;
            finish();
        });
    }

    function expandAvatarPanel(container, wrapper, toggle) {
        const content = container.closest('.es__content');

        clearContentHeightAnimation(content);
        container.classList.remove('is-collapsing');
        container.classList.add('is-expanded');
        toggle.textContent = toggle.dataset.hideText || 'Hide';
        syncContentExpanded(container);

        const targetHeight = wrapper.scrollHeight;
        const collapsedPx = getCollapsedHeightPx(wrapper);

        wrapper.style.setProperty('--es-avatars-expanded-height', `${collapsedPx}px`);
        void wrapper.offsetHeight;
        wrapper.style.setProperty('--es-avatars-expanded-height', `${targetHeight}px`);

        if (prefersReducedMotion()) {
            setAvatarOverflow(container);
            return;
        }

        runHeightTransition(wrapper, () => setAvatarOverflow(container));
    }

    let avatarOverflowTimer = null;

    function scheduleAvatarOverflow(container, delay = 250) {
        if (!container) return;

        clearTimeout(avatarOverflowTimer);
        avatarOverflowTimer = setTimeout(() => setAvatarOverflow(container), delay);
    }

    function setAvatarOverflow(container, force = false) {
        if (!container || container.hidden) return;

        const wrapper = $('.es__cards-wrapper-small', container);
        if (!wrapper || wrapper.classList.contains('is-animating')) return;

        if (container.classList.contains('is-expanded')) {
            return;
        }

        const overflow = wrapper.scrollHeight - wrapper.clientHeight > 1;
        const hadOverflow = container.classList.contains('has-overflow');

        if (!force && hadOverflow === overflow) return;

        container.classList.toggle('has-overflow', overflow);
    }

    const avatarImageIo = 'IntersectionObserver' in window
        ? new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;

                const img = entry.target;
                const src = img.getAttribute('data-src');

                if (!src) {
                    avatarImageIo.unobserve(img);
                    return;
                }

                const onDone = () => {
                    img.removeAttribute('data-src');
                    const avatars = img.closest('.es__scroller-avatars');
                    if (avatars) scheduleAvatarOverflow(avatars, 50);
                };

                img.addEventListener('load', onDone, { once: true });
                img.addEventListener('error', onDone, { once: true });
                img.src = src;
                avatarImageIo.unobserve(img);
            });
        }, { rootMargin: '120px 0px' })
        : null;

    function initAvatarImages(root = document) {
        $$('img.es__avatar-img[data-src]', root).forEach(img => {
            if (!avatarImageIo) {
                const src = img.getAttribute('data-src');
                if (src) img.src = src;
                img.removeAttribute('data-src');
                return;
            }

            avatarImageIo.observe(img);
        });
    }

    function afterAvatarsRender(wrapper, resetPanel = true) {
        const container = $('#avatars-container');
        if (!wrapper || !container) return;

        initAvatarImages(wrapper);

        if (resetPanel) {
            resetAvatarPanel(container);
        }

        scheduleAvatarOverflow(container, 0);
        requestAnimationFrame(() => scheduleAvatarOverflow(container, 100));
    }

    function resetAvatarPanel(container) {
        if (!container) return;

        const wrapper = $('.es__cards-wrapper-small', container);
        const toggle = $('[data-es-avatars-toggle]', container);

        if (toggle) toggle.textContent = toggle.dataset.showText || 'Show all';
        if (wrapper) finishAvatarCollapse(container, wrapper);
    }

    function initAvatarToggle(toggle) {
        if (toggle.esInit) return;

        toggle.esInit = true;
        const container = toggle.closest('.es__scroller-avatars');
        const wrapper = container && $('.es__cards-wrapper-small', container);
        if (!container || !wrapper) return;

        toggle.addEventListener('click', () => {
            if (container.classList.contains('is-expanded')) {
                collapseAvatarPanel(container, wrapper, toggle);
                return;
            }

            expandAvatarPanel(container, wrapper, toggle);
        });

        window.addEventListener('resize', () => scheduleAvatarOverflow(container));
        resetAvatarPanel(container);
    }

    function init(root = document) {
        $$('[data-es-scroller]', root).forEach(initScroller);
        $$('[data-es-avatars-toggle]', root).forEach(initAvatarToggle);
    }

    function renderFeedAvatar(url, attrs = '') {
        return `<img src="${AVATAR_PLACEHOLDER}" data-src="${esc(url)}" class="es__card-avatar es__avatar-img" decoding="async" loading="lazy" ${attrs}>`;
    }

    function renderPunishment(p) {
        const types = {
            0: ['block', '_punishGameBlock'],
            1: ['micro-slash', '_punishMicBlock'],
            2: ['chat-slash', '_punishChatBlock'],
            3: ['face-mute', '_punishChatMicBlock'],
        };
        const [icon, titleKey] = types[p.type] || types[0];
        const steamid = esc(p.steamid);
        const game = String(p.game || 'csgo').toLowerCase() === 'cs2' ? 'cs2' : 'csgo';
        const removed = Boolean(p.unbanned);
        const status = removed
            ? phrase('_punishRemoved')
            : (p.duration ? `${phrase('_punishUntil')} ${time(p.duration)}` : phrase('_punishForever'));

        rememberAvatar(p.check_avatar, p.steamid);

        return `
            <div class="es__card ${removed ? 'es__card-punish-status-inactive' : 'es__card-punish-status-active'}">
                <a href="/profiles/${steamid}/?search=1" class="es__card-name">
                    ${renderFeedAvatar(p.avatar, `id="avatar" avatarid="${steamid}" alt=""`)}
                    <span id="name" nameid="${steamid}">${p.name}</span>
                    <div class="es__card-type type-punishment" data-tippy-content="${esc(phrase(titleKey))}">
                        <svg><use href="/resources/img/sprite.svg#${icon}"></use></svg>
                    </div>
                </a>
                <div class="es__card-info">
                    <span class="es__card-info-item reason">${esc(p.reason)}</span>
                    <span class="es__card-info-item time">
                        <svg><use href="/resources/img/sprite.svg#calendare"></use></svg>
                        ${time(p.created)}
                        <div class="es__card-punish-status ${removed ? 'unbanned' : 'banned'}" data-tippy-content="${esc(status)}">
                            <svg><use href="/resources/img/sprite.svg#${removed ? 'unlock' : 'lock'}"></use></svg>
                        </div>
                        <div class="es__card-game-icon ${game}" data-tippy-content="${game.toUpperCase()}">
                            <svg><use href="/resources/img/sprite.svg#${game}"></use></svg>
                        </div>
                    </span>
                </div>
            </div>
        `;
    }

    function renderBuy(p) {
        const steamid = esc(p.steamid);
        rememberAvatar(p.check_avatar, p.steamid);

        return `
            <div class="es__card es__card-buy-status-active">
                <a href="/profiles/${steamid}/?search=1" class="es__card-name">
                    ${renderFeedAvatar(p.avatar, `id="avatar" avatarid="${steamid}" alt=""`)}
                    <span id="name" nameid="${steamid}">${p.name}</span>
                    <div class="es__card-type type-buy"><svg><use href="/resources/img/sprite.svg#store-build"></use></svg></div>
                </a>
                <div class="es__card-info">
                    <span class="es__card-info-item reason">
                        <span>${phrase('_purchase')}: ${esc(p.item)}</span>
                        <span class="es__dot">&bull;</span>
                        <span>${esc(p.duration)}</span>
                    </span>
                    <span class="es__card-info-item time">
                        <svg><use href="/resources/img/sprite.svg#calendare"></use></svg>
                        ${time(p.date)}
                        <div class="es__card-buy-status active" data-tippy-placement="top" data-tippy-content="${esc(phrase('_statusActive'))}">
                            <svg><use href="/resources/img/sprite.svg#check"></use></svg>
                        </div>
                        <div class="es__card-servers" data-tippy-placement="top" data-tippy-content="${esc(`${phrase('_purchaseServers')}: ${p.server || ''}`)}">
                            <svg><use href="/resources/img/sprite.svg#servers"></use></svg>
                        </div>
                    </span>
                </div>
            </div>
        `;
    }

    function renderAvatar(item, guest = false) {
        const steamid = item.steamid ? esc(item.steamid) : '';
        const name = guest ? phrase('_guest') : item.name;
        const link = steamid
            ? `href="/profiles/${steamid}/?search=1" target="_blank" rel="noopener"`
            : 'role="link" aria-disabled="true"';

        rememberAvatar(item.check_avatar, item.steamid);

        return `
            <div class="es__card-small" data-tippy-placement="top" data-tippy-content="${esc(name)}">
                <a ${link}>
                    <img src="${AVATAR_PLACEHOLDER}" data-src="${esc(item.avatar)}" alt="${esc(name)}" id="avatar" avatarid="${steamid}" class="es__avatar-img" decoding="async" loading="lazy">
                </a>
            </div>
        `;
    }

    function makeItemKey(tabKey, item, index) {
        const p = `${tabKey}::`;
        switch (tabKey) {
            case 'lastBans':
                return p + [item.steamid, item.created, item.type, item.reason, item.game].join('|');
            case 'lastBuys':
                return p + [item.steamid, item.date, item.item, item.server, item.duration].join('|');
            case 'todayVisits':
                return p + [item.steamid, item.last_visit, index].join('|');
            case 'nowOnline':
                return p + [item.steamid || item.user || 'guest', index].join('|');
            default:
                return p + String(index);
        }
    }

    function payloadSignature(tabKey, list) {
        return list.map((item, index) => makeItemKey(tabKey, item, index)).join('||');
    }

    function animateFeedCards(wrapper) {
        if (!wrapper || prefersReducedMotion()) return;

        const cards = $$('.es__card', wrapper);
        if (!cards.length) return;

        cards.forEach((card, index) => {
            card.classList.remove('es__card--enter');
            card.style.removeProperty('--es-card-enter-delay');
            card.style.setProperty('--es-card-enter-delay', `${Math.min(index, 10) * 40}ms`);
        });

        requestAnimationFrame(() => {
            cards.forEach(card => card.classList.add('es__card--enter'));
        });
    }

    function patchWrapper(wrapper, tabKey, list, renderItem, serverHash = '') {
        if (wrapper.dataset.esActiveTab && wrapper.dataset.esActiveTab !== tabKey) {
            delete renderState[tabKey];
        }

        const nextSignature = payloadSignature(tabKey, list);
        if (renderState[tabKey]?.signature === nextSignature) {
            return false;
        }

        const html = list.map(item => renderItem(item)).join('');
        wrapper.innerHTML = html;
        if (wrapper.id === 'live-feed-wrapper') {
            animateFeedCards(wrapper);
        }
        renderState[tabKey] = { signature: nextSignature, serverHash };
        wrapper.dataset.esActiveTab = tabKey;

        if (wrapper.id === 'live-feed-wrapper') {
            feedPanelCache[tabKey] = {
                html,
                scrollLeft: wrapper.scrollLeft,
            };
        }

        return true;
    }

    function restoreFeedPanel(tabKey) {
        const track = $('#live-feed-wrapper');
        const cached = feedPanelCache[tabKey];

        if (!track || !cached?.html) return false;

        track.innerHTML = cached.html;
        track.dataset.esActiveTab = tabKey;
        track.scrollLeft = cached.scrollLeft || 0;
        initTooltips(track);
        initAvatarImages(track);
        requestAnimationFrame(() => track.closest('.es__scroller')?.esExtStats?.refresh());

        return true;
    }

    function applyTabPayload(tabKey, payload) {
        const tab = tabs[tabKey];
        const wrapper = tab && $(tab.wrapper);

        if (!tab || !wrapper) return false;

        const list = Array.isArray(payload)
            ? payload
            : (Array.isArray(payload?.items) ? payload.items : []);
        const serverHash = typeof payload?.meta?.hash === 'string' ? payload.meta.hash : '';
        const changed = patchWrapper(wrapper, tabKey, list, tab.renderItem, serverHash);

        if (!changed && tab.type !== 'feed') return false;

        initTooltips(wrapper);

        if (tab.type === 'feed') {
            initAvatarImages(wrapper);
            requestAnimationFrame(() => wrapper.closest('.es__scroller')?.esExtStats?.refresh());
        } else {
            afterAvatarsRender(wrapper, false);
        }

        return changed;
    }

    const tabs = {
        lastBans: { type: 'feed', wrapper: '#live-feed-wrapper', renderItem: renderPunishment },
        lastBuys: { type: 'feed', wrapper: '#live-feed-wrapper', renderItem: renderBuy },
        todayVisits: { type: 'avatars', wrapper: '#avatars-wrapper', renderItem: item => renderAvatar(item) },
        nowOnline: { type: 'avatars', wrapper: '#avatars-wrapper', renderItem: item => renderAvatar(item) },
    };

    function storedTabOrDefault(stored) {
        if (!stored || !tabs[stored]) return DEFAULT_TAB;
        return stored;
    }

    function initTooltips(root) {
        if (typeof window.tippy !== 'function') return;

        $$('[data-tippy-content]', root).forEach(el => {
            if (el._tippy) return;

            window.tippy(el, {
                placement: el.dataset.tippyPlacement || 'top',
                arrow: false,
                animation: 'shift-away',
                theme: 'neo',
                allowHTML: true,
                appendTo: () => document.body,
                popperOptions: { strategy: 'fixed' },
            });
        });
    }

    function showContainer(type) {
        const feed = $('#live-feed-scroller');
        const avatars = $('#avatars-container');
        if (!feed || !avatars) return;

        feed.hidden = type !== 'feed';
        avatars.hidden = type !== 'avatars';
    }

    function activateTab(tabKey) {
        const tab = tabs[tabKey] ? tabKey : DEFAULT_TAB;
        const meta = tabs[tab];
        const track = $('#live-feed-wrapper');

        if (activeTab && tabs[activeTab]?.type === 'feed' && track) {
            feedPanelCache[activeTab] = {
                html: track.innerHTML,
                scrollLeft: track.scrollLeft,
            };
        }

        activeTab = tab;
        $$('.es__buttons .filter').forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
        showContainer(meta.type);

        if (meta.type === 'feed') {
            resetAvatarPanel($('#avatars-container'));

            if (!restoreFeedPanel(tab)) {
                const cachedData = responseCache[`tab_${tab}`]?.data;
                if (cachedData) applyTabPayload(tab, cachedData);
            }
        } else if (meta.type === 'avatars') {
            const avatars = $('#avatars-container');
            const avatarsWrapper = $('#avatars-wrapper');
            const cachedData = responseCache[`tab_${tab}`]?.data;

            if (cachedData && avatarsWrapper) {
                applyTabPayload(tab, cachedData);
            }

            requestAnimationFrame(() => {
                if (avatarsWrapper) afterAvatarsRender(avatarsWrapper, true);
            });
        }

        localStorage.setItem(TAB_KEY, tab);
        loadTab(tab);
    }

    async function fetchJson(tabKey, cacheKey) {
        const base = new URL('/home/extstats/', window.location.href).href.replace(/\/?$/, '/');
        const url = new URL(`${tabKey}/`, base);
        url.searchParams.set('meta', '1');

        const cached = responseCache[cacheKey];
        const now = Date.now();
        const clientCacheTtlMs = REFRESH_INTERVAL;
        const headers = {
            Accept: 'application/json',
        };

        if (cached && now - (cached.cachedAt || 0) < clientCacheTtlMs) {
            return cached.data;
        }

        if (cached && cached.etag) {
            headers['If-None-Match'] = cached.etag;
        }

        const res = await fetch(url.toString(), {
            method: 'GET',
            headers: headers,
            cache: 'no-cache',
        });

        if (res.status === 304 && cached) {
            cached.cachedAt = now;
            return cached.data;
        }

        if (!res.ok) {
            throw new Error(`HTTP ${res.status}`);
        }

        const contentType = res.headers.get('content-type') || '';
        if (!contentType.includes('application/json')) {
            throw new Error(`Expected JSON, got: ${contentType || 'no Content-Type'} (HTTP ${res.status})`);
        }

        const payload = await res.json();
        responseCache[cacheKey] = {
            data: payload,
            etag: res.headers.get('ETag') || '',
            cachedAt: now,
        };

        return payload;
    }

    async function loadTab(tabKey, resetPanel = true) {
        const tab = tabs[tabKey];
        const wrapper = tab && $(tab.wrapper);
        const currentLoadId = ++loadId;

        if (!tab || !wrapper) return;

        try {
            const payload = await fetchJson(tabKey, `tab_${tabKey}`);
            if (tabKey !== activeTab || currentLoadId !== loadId) return;

            const list = Array.isArray(payload)
                ? payload
                : (Array.isArray(payload?.items) ? payload.items : []);
            const serverHash = typeof payload?.meta?.hash === 'string' ? payload.meta.hash : '';

            const changed = patchWrapper(wrapper, tabKey, list, tab.renderItem, serverHash);

            if (tab.type === 'avatars') {
                initTooltips(wrapper);
                afterAvatarsRender(wrapper, resetPanel);
                return;
            }

            if (!changed) return;

            initTooltips(wrapper);
            initAvatarImages(wrapper);
            requestAnimationFrame(() => wrapper.closest('.es__scroller')?.esExtStats?.refresh());
        } catch (error) {
            if (tabKey !== activeTab || currentLoadId !== loadId) return;

            console.error('Error loading tab:', error);
            wrapper.innerHTML = `<div class="no-data">${esc(phrase('_no_data'))}</div>`;
        }
    }

    function shouldAutoRefresh() {
        return Boolean(activeTab) && !document.hidden && document.visibilityState === 'visible' && document.hasFocus();
    }

    function stopAutoRefresh() {
        if (refreshTimer) {
            clearTimeout(refreshTimer);
            refreshTimer = null;
        }
    }

    function scheduleAutoRefresh() {
        stopAutoRefresh();
        if (!shouldAutoRefresh()) return;

        refreshTimer = setTimeout(async () => {
            if (!shouldAutoRefresh()) {
                stopAutoRefresh();
                return;
            }

            await loadTab(activeTab, false);
            scheduleAutoRefresh();
        }, REFRESH_INTERVAL);
    }

    document.addEventListener('DOMContentLoaded', () => {
        init();
        $$('[data-tab]').forEach(btn => {
            btn.addEventListener('click', e => {
                e.preventDefault();
                activateTab(btn.dataset.tab);
                scheduleAutoRefresh();
            });
        });
        activateTab(storedTabOrDefault(localStorage.getItem(TAB_KEY)));
        scheduleAutoRefresh();

        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                stopAutoRefresh();
                return;
            }

            if (activeTab) loadTab(activeTab, false);
            scheduleAutoRefresh();
        });

        window.addEventListener('focus', () => {
            if (activeTab) loadTab(activeTab, false);
            scheduleAutoRefresh();
        });
        window.addEventListener('blur', stopAutoRefresh);
        window.addEventListener('pageshow', scheduleAutoRefresh);
        window.addEventListener('pagehide', stopAutoRefresh);
    });

    window.ExtStatsScroller = {
        init: init,
    };
})();
